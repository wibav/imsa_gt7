rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Lectura pública de imágenes/layouts para la web
    match /{allPaths=**} {
      allow read: if true;

      // Escritura solo para usuarios autenticados y archivos de imagen
      allow write: if request.auth != null
        && request.resource != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
